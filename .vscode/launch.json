{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Clarity Diff Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Run Clarity Diff in a test project",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../clarity-diff-testbed",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: build"
    }
  ]
}
